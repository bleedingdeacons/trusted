{
    "name": "trusted/trusted",
    "description": "Trusted — a 7-day telephone shift rota manager for WordPress, built on the Unity plugin.",
    "type": "wordpress-plugin",
    "license": "MIT (Modified)",
    "require": {
        "php": ">=8.1",
        "psr/container": "^1.1 || ^2.0"
    },
    "autoload": {
        "psr-4": {
            "Trusted\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "build:production": "php build.php build:production",
        "build:dev": "php build.php build:dev",
        "build:clean": "php build.php clean"
    }
}
